{
  "uid": "energyhub-infra",
  "title": "EnergyHub · Infraestrutura",
  "tags": ["energyhub", "infrastructure"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Memória do host (usada / disponível)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "options": {},
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "memory_usage_bytes",
          "legendFormat": "usada"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "memory_available_bytes",
          "legendFormat": "disponível"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "CPU do host (%)",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percent", "max": 100 }, "overrides": [] },
      "options": {},
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "cpu_usage_percent",
          "legendFormat": "cpu %"
        }
      ]
    },
    {
      "id": 3,
      "type": "gauge",
      "title": "Disco do host (%)",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percent", "max": 100 }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "disk_usage_percent",
          "legendFormat": "disco %"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Latência da busca (Elasticsearch · p95 do endpoint /search)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "options": {},
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(fastapi_request_duration_seconds_bucket{handler=~\"/api/v1/search/clients.*\"}[5m])) by (le))",
          "legendFormat": "p95 busca"
        }
      ]
    }
  ]
}
